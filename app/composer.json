{
    "name": "projectname/projectname",
    "description": "PHP Project template",
    "type": "project",
    "license": "A_LICENSE",
    "autoload": {
        "psr-4": {
            "src\\": "src/"
        },
        "files": [
            "config/config.php",
            "src/core/utils/utils.php"
        ]
    },
    "authors": [
        {
            "name": "a_name",
            "email": "an_email@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": "^8.2",
        "vlucas/phpdotenv": "^5.6",
        "league/plates": "^3.5",
        "castroitalo/echoquery": "^1.0",
        "ext-pdo": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "mockery/mockery": "^1.6"
    },
    "scripts": {
        "sass": "sass --watch public/static/styles/scss:public/static/styles/css",
        "sass_compressed": "public/static/styles/scss:public/static/styles/css compressed",
        "tests": "vendor/bin/phpunit --testsuit unit --colors --testdox tests"
    }
}